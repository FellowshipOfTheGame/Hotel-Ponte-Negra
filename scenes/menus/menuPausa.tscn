[gd_scene load_steps=2 format=3 uid="uid://b13kmc0a4s1nf"]

[sub_resource type="GDScript" id="MenuPausa"]
script/source = "extends Control

func _input(event: InputEvent) -> void:
	if event.is_action_pressed(\"_pausa\"):
		get_viewport().set_input_as_handled()
		voltar()

func voltar():
	get_tree().paused=false
	Input.mouse_mode=Input.MOUSE_MODE_CAPTURED
	queue_free()

func menuPrincipal() -> void:
	get_tree().paused=false
	get_tree().change_scene_to_file(\"res://scenes/menus/menuPrincipal.tscn\")

func opcoes() -> void:
	var menu:=preload(\"res://scenes/menus/menuOpcoes.tscn\").instantiate()
	menu.prev=\"res://scenes/menus/menuPausa.tscn\"
	get_parent().add_child(menu)
	queue_free()


func sair() -> void:
	get_tree().quit()
"

